{
  "useTabs": false,
  "tabWidth": 2,
  "printWidth": 120,
  "singleQuote": true,
  "jsxSingleQuote": false,
  "quoteProps": "as-needed",
  "trailingComma": "all",
  "semi": true,
  "arrowParens": "always",
  "bracketSameLine": false,
  "bracketSpacing": true,
  "ignorePatterns": [
    "**/CHANGELOG.md",
    "**/pnpm-lock.yaml",
    "**/node_modules",
    "**/build",
    "**/dist",
    "**/.claude",
    "**/.next",
    "**/.source",
    "**/*.gen.ts"
  ]
}
