{
  "name": "graneet-form",
  "private": true,
  "keywords": [
    "form",
    "forms",
    "react",
    "typescript",
    "validation"
  ],
  "homepage": "https://github.com/graneet/graneet-form",
  "bugs": {
    "url": "https://github.com/graneet/graneet-form/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git@github.com:graneet/graneet-form.git"
  },
  "sideEffects": false,
  "scripts": {
    "start:dev": "pnpm -r dev",
    "build:docs": "pnpm --filter docs build",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "release": "pnpm --filter graneet-form build && changeset publish",
    "test": "exit 0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.31.0",
    "oxfmt": "0.55.0",
    "oxlint": "1.70.0",
    "oxlint-tsgolint": "0.23.0",
    "typescript": "6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "@tailwindcss/oxide",
      "core-js",
      "esbuild",
      "sharp"
    ]
  }
}
