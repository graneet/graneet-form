{
  "name": "graneet-form",
  "version": "3.3.0",
  "keywords": [
    "form",
    "forms",
    "react",
    "typescript",
    "validation"
  ],
  "homepage": "https://github.com/graneet/graneet-form",
  "bugs": {
    "url": "https://github.com/graneet/graneet-form/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/graneet/graneet-form.git"
  },
  "type": "module",
  "sideEffects": false,
  "types": "dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "tsdown --config tsdown.config.ts --env.NODE_ENV development",
    "build": "tsdown --publint --config tsdown.config.ts --env.NODE_ENV production",
    "lint": "oxlint ./src ./app ./docs",
    "release": "standard-version",
    "release:minor": "standard-version --release-as minor",
    "release:patch": "standard-version --release-as patch",
    "release:major": "standard-version --release-as major",
    "typecheck": "tsc --noEmit --project ./tsconfig.json",
    "test": "vitest run --typecheck",
    "test:watch": "vitest --typecheck"
  },
  "devDependencies": {
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "publint": "0.3.21",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "rollup": "4.62.0",
    "tsdown": "0.22.3",
    "tslib": "2.8.1",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "peerDependencies": {
    "react": "^19"
  }
}
